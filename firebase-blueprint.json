{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "email": { "type": "string", "description": "User's email address." },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "User's preferred theme." },
        "language": { "type": "string", "description": "User's preferred language." },
        "notificationsEnabled": { "type": "boolean", "description": "Whether notifications are enabled." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "Represents a conversation session.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique session ID." },
        "userId": { "type": "string", "description": "ID of the user who owns this session." },
        "title": { "type": "string", "description": "Title of the chat session." },
        "lastMessage": { "type": "string", "description": "The last message sent in this session." },
        "isFavorite": { "type": "boolean", "description": "Whether the session is marked as favorite." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the session was last updated." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the session was created." }
      },
      "required": ["userId", "title"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat session.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string", "description": "ID of the parent chat session." },
        "userId": { "type": "string", "description": "ID of the user who sent the message (or 'ai')." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Role of the message sender." },
        "content": { "type": "string", "description": "Text content of the message." },
        "type": { "type": "string", "enum": ["text", "code", "image_analysis"], "description": "Type of content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["sessionId", "role", "content"]
    },
    "GeneratedImage": {
      "title": "Generated Image",
      "description": "Stores metadata for images generated by the AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who generated the image." },
        "prompt": { "type": "string", "description": "The prompt used to generate the image." },
        "imageUrl": { "type": "string", "description": "URL of the generated image (base64 or storage link)." },
        "style": { "type": "string", "description": "Style used for generation." },
        "isFavorite": { "type": "boolean", "description": "Whether the image is marked as favorite." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the image was generated." }
      },
      "required": ["userId", "prompt", "imageUrl"]
    },
    "GeneratedCode": {
      "title": "Generated Code",
      "description": "Stores metadata for code snippets generated by the AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who generated the code." },
        "prompt": { "type": "string", "description": "The prompt used to generate the code." },
        "code": { "type": "string", "description": "The generated code content." },
        "language": { "type": "string", "description": "Programming language of the code." },
        "explanation": { "type": "string", "description": "AI's explanation of the code." },
        "isFavorite": { "type": "boolean", "description": "Whether the code is marked as favorite." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the code was generated." }
      },
      "required": ["userId", "prompt", "code"]
    },
    "IdeaAnalysis": {
      "title": "Idea Analysis",
      "description": "Stores results of business or content idea analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who requested analysis." },
        "idea": { "type": "string", "description": "The original idea text." },
        "analysis": { "type": "string", "description": "The AI's analysis and suggestions." },
        "score": { "type": "number", "description": "Predicted success score (0-100)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the analysis was performed." }
      },
      "required": ["userId", "idea", "analysis"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Chat session documents."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat session."
    },
    "/images/{imageId}": {
      "schema": "GeneratedImage",
      "description": "Generated image metadata."
    },
    "/code/{codeId}": {
      "schema": "GeneratedCode",
      "description": "Generated code metadata."
    },
    "/ideas/{ideaId}": {
      "schema": "IdeaAnalysis",
      "description": "Idea analysis results."
    }
  }
}
